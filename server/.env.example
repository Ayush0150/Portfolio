# Express server port
PORT=5050

# MongoDB connection string (e.g. MongoDB Atlas). Leave empty to run without persistence.
MONGODB_URI=

# Comma-separated allowed origins for CORS (your client URL)
CLIENT_URL=http://localhost:5173

# Email delivery via Resend (optional). Messages are still saved to MongoDB without it.
RESEND_API_KEY=
CONTACT_EMAIL=raiaayushrai2005@gmail.com
